{
  "kind": "collectionType",
  "collectionName": "works",
  "info": {
    "singularName": "work",
    "pluralName": "works",
    "displayName": "Work",
    "description": "Portfolio project / case study"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "maxLength": 120,
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "shortDescription": {
      "type": "text",
      "maxLength": 280
    },
    "mainImage": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "clientName": {
      "type": "string",
      "maxLength": 120
    },
    "clientType": {
      "type": "enumeration",
      "enum": [
        "Executed",
        "Reimagined",
        "Conceptual"
      ],
      "displayName": "Client Type"
    },
    "location": {
      "type": "string",
      "maxLength": 120
    },
    "preEventMarketingPoints": {
      "type": "component",
      "repeatable": false,
      "component": "shared.marketing-group",
      "displayName": "Pre-Event Marketing"
    },
    "postEventMarketingPoints": {
      "type": "component",
      "repeatable": false,
      "component": "shared.marketing-group",
      "displayName": "Post-Event Marketing"
    },
    "launchEventExperiencePoints": {
      "type": "component",
      "repeatable": true,
      "component": "shared.bullet-point",
      "displayName": "Launch Event Experience"
    },
    "campaignImpactPoints": {
      "type": "component",
      "repeatable": true,
      "component": "shared.bullet-point",
      "displayName": "Campaign Impact"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "displayOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
