{
  "kind": "collectionType",
  "collectionName": "workshops",
  "info": {
    "singularName": "workshop",
    "pluralName": "workshops",
    "displayName": "Workshop",
    "description": "Workshop / training session"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "workshopType": {
      "type": "enumeration",
      "enum": [
        "openworkshop"
      ],
      "default": "openworkshop",
      "required": true,
      "displayName": "Workshop Type"
    },
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 120,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "shortDescription": {
      "type": "text",
      "maxLength": 280,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "whatYouWillLearnPoints": {
      "type": "component",
      "repeatable": true,
      "component": "shared.bullet-point",
      "displayName": "What You'll Learn",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "formatDetails": {
      "type": "text",
      "displayName": "Format",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "datesDetails": {
      "type": "date",
      "displayName": "Date"
    },
    "mainImage": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "displayOrder": {
      "type": "integer",
      "default": 0
    }
  }
}
